# ── SAP EMT 601 (SAP PPS OData) ────────────────────────────────────
SAP_EMT601_URL=https://ldciemt.wdf.sap.corp:44322
SAP_EMT601_CLIENT=601
SAP_EMT601_USER=your-user
SAP_EMT601_PASSWORD=your-password
SAP_MAX_RETRIES=3
SAP_TIMEOUT_SEC=15
SAP_BACKOFF_BASE=2

# ── AI backend - pick ONE ──────────────────────────────────────────
# Option A: SAP AI Core (production)
# AICORE_CLIENT_ID=
# AICORE_SECRET=
# AICORE_AUTH_URL=
# AICORE_BASE_URL=
# CLAUDE_MODEL=sap/anthropic--claude-4.5-sonnet

# Option B: Hyperspace proxy (local dev)
HYPERSPACE_API_KEY=your-key
HYPERSPACE_URL=http://localhost:6655/anthropic
CLAUDE_MODEL=claude-opus-4-5

# ── v3.0 Template Loader (E1) ──────────────────────────────────────
TEMPLATE_CACHE_TTL_SEC=172800
TEMPLATE_LIVE_TIMEOUT_SEC=5
TEMPLATE_PREFER_LIVE=true

# ── v3.0 Response Cache (E6) ───────────────────────────────────────
SYNOPSIS_CACHE_ENABLED=true
SYNOPSIS_CACHE_TTL_SEC=3600

# ── v3.0 Weighted Validator (E5) ───────────────────────────────────
VALIDATOR_PASS_THRESHOLD=70
VALIDATOR_CRITICAL_FLOOR=50
VALIDATOR_MAX_ATTEMPTS=2

# ── v3.0 SAP Agent Memory (E8) ─────────────────────────────────────
# Set false to run offline / in local dev without BTP binding
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_AGENT_ID=tender-synopsis-agent
# The two below are auto-injected by the BTP service binding
# CLOUD_SDK_CFG_HANA_AGENT_MEMORY_DEFAULT_APPLICATION_URL=
# CLOUD_SDK_CFG_HANA_AGENT_MEMORY_DEFAULT_UAA={"clientid":"...","clientsecret":"...","url":"..."}